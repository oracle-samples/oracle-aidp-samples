# oracle-ai-data-platform-fusion-bundle — example environment variables
#
# Copy to .env (gitignored) for local dev. Production: prefer OCI Vault refs in bundle.yaml.

# -------- AIDP --------
AIDP_WORKSPACE_KEY=                          # e.g. 54368733-3a17-47a1-b231-869d8ae2a048
AIDP_REGION=us-ashburn-1
AIDP_OCI_PROFILE=AIDP_SESSION                # OCI session profile for AIDP REST/MCP
AIDP_CLUSTER=tpcds
AIDP_CATALOG=fusion_catalog                  # to be created via P0-5

# -------- Fusion BICC (HTTP Basic, BIAdmin role required) --------
# Demo pod confirmed working with Casey.Brown / BIAdmin (RESULTS.md row 10).
FUSION_BICC_BASE_URL=https://fa-etap-dev5-saasfademo1.ds-fa.oraclepdemos.com
FUSION_BICC_USER=Casey.Brown
FUSION_BICC_PASSWORD=                        # from OCI Vault in production
FUSION_BICC_SCHEMA=Financial                 # ERP also accepted by some pods/releases
FUSION_BICC_EXTERNAL_STORAGE=                # BICC console External Storage profile name (set in BICC's "Configure External Storage" tab; no AIDP-side registration)

# -------- Fusion saas-batch REST (NEW from pdf2; v1.5 path) --------
FUSION_SAAS_BATCH_HOST=                      # same pod host typically
FUSION_SAAS_BATCH_POD=                       # pod name for the audience param
FUSION_SAAS_BATCH_USER=
FUSION_SAAS_BATCH_PASSWORD=

# -------- OCI Object Storage (BICC writes to this bucket) --------
OCI_NAMESPACE=                               # tenancy namespace
OCI_BUCKET_BICC=fusion-bicc-saasfademo1      # P0-1
OCI_COMPARTMENT_OCID=                        # AIDP_TPC-DS_Ahmed compartment OCID

# -------- OCI Vault (production credential store) --------
OCI_VAULT_OCID=
FUSION_BICC_PASSWORD_VAULT_OCID=             # ocid1.vaultsecret... for FUSION_BICC_PASSWORD
OAC_REST_CLIENT_SECRET_VAULT_OCID=           # OAC REST API client secret

# -------- Oracle Analytics Cloud (OAC) — for `dashboard install` --------
OAC_URL=                                     # https://<your-oac-host>
OAC_OAUTH_CLIENT_ID=
OAC_OAUTH_CLIENT_SECRET=                     # from OCI Vault in production
OAC_DATA_SOURCE_NAME=aidp_fusion_jdbc        # name to register inside OAC

# -------- AIDP Spark Thrift JDBC (OAC connects to this) --------
AIDP_THRIFT_JDBC_URL=                        # jdbc:spark://<host>:443/fusion_catalog;...
AIDP_THRIFT_JDBC_USER=
AIDP_THRIFT_JDBC_PASSWORD_VAULT_OCID=
