{
  "name": "aidp-cli",
  "version": "1.0.0",
  "description": "Command line interface for AI Data Platform data plane public APIs.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aidp": "./dist/bin/aidp.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "dist/**/*.json",
    "LICENSE.txt",
    "NOTICE.txt"
  ],
  "scripts": {
    "build": "./node_modules/typescript/bin/tsc -p tsconfig.json",
    "generate-manifest": "node scripts/generate_manifest.js",
    "prepack": "npm run build && npm run generate-manifest && node scripts/prepare_pack_metadata.js",
    "postpack": "node scripts/restore_pack_metadata.js",
    "test": "npm run build && npm run generate-manifest && node test/run_tests.js",
    "write-version": "node scripts/write_version.js"
  },
  "author": {
    "name": "Oracle Cloud Infrastructure",
    "email": ""
  },
  "license": "(UPL-1.0 OR Apache-2.0)",
  "dependencies": {
    "aidp-typescript-client": "1.0.0",
    "oci-common": "2.126.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/node-fetch": "^2.6.12",
    "typescript": "^5.8.3"
  }
}
