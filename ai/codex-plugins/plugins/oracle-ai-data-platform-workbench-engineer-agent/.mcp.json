{
  "mcp_servers": {
    "aidp": {
      "command": "python",
      "args": ["-m", "aidp_agent.mcp_server"],
      "env": {
        "AIDP_REGION": "us-ashburn-1",
        "AIDP_DATA_LAKE_ID": "<DATALAKE_OCID>",
        "AIDP_WORKSPACE_ID": "<WORKSPACE>",
        "AIDP_AUTH_TYPE": "api_key",
        "OCI_BASE_CONFIG_PROFILE": "DEFAULT"
      }
    }
  }
}
