              "startTime": "$(params.time.start)",
              "endTime": "$(params.time.end)",
              "namespace": "oracle_aidataplatform",
              "mql": "JobRunDuration[5m]{{ '$(params.job)'!=''&&'$(params.job)'!='*' ? ('$(params.aidp)'!=''&&'$(params.aidp)'!='*' ? '{resourceId =~ \"$(params.aidp)\",jobName =~ \"$(params.job)\"}' : '{jobName =~ \"$(params.job)\"}') : ('$(params.aidp)'!=''&&'$(params.aidp)'!='*' ? '{resourceId =~ \"$(params.aidp)\"}' : '') }}.grouping(jobName).mean()"
            }
          }
        ],
